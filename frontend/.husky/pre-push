#!/bin/sh
# Run pre-push checks from git root
echo "=== Running Pre-Push Lint & Typecheck Checks ==="

cd frontend

# Run linting
pnpm lint
LINT_STATUS=$?

if [ $LINT_STATUS -ne 0 ]; then
  echo "ESLint failed. Push aborted........."
  exit 1
fi

# Run type checking
pnpm typecheck
TSC_STATUS=$?

if [ $TSC_STATUS -ne 0 ]; then
  echo "TypeScript type checking failed. Push aborted........"
  exit 1
fi

echo "All checks passed successfully!"
exit 0
